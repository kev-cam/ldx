    y_inv = inv_W2[0] * h_inv[0] + inv_W2[1] * h_inv[1] + inv_W2[2] * h_inv[2] + inv_W2[3] * h_inv[3] + inv_W2[4] * h_inv[4] + inv_W2[5] * h_inv[5] + inv_W2[6] * h_inv[6] + inv_W2[7] * h_inv[7] + inv_W2[8] * h_inv[8] + inv_W2[9] * h_inv[9] + inv_W2[10] * h_inv[10] + inv_W2[11] * h_inv[11] + inv_W2[12] * h_inv[12] + inv_W2[13] * h_inv[13] + inv_W2[14] * h_inv[14] + inv_W2[15] * h_inv[15] + inv_W2[16] * h_inv[16] + inv_W2[17] * h_inv[17] + inv_W2[18] * h_inv[18] + inv_W2[19] * h_inv[19] + inv_W2[20] * h_inv[20] + inv_W2[21] * h_inv[21] + inv_W2[22] * h_inv[22] + inv_W2[23] * h_inv[23] + inv_W2[24] * h_inv[24] + inv_W2[25] * h_inv[25] + inv_W2[26] * h_inv[26] + inv_W2[27] * h_inv[27] + inv_W2[28] * h_inv[28] + inv_W2[29] * h_inv[29] + inv_W2[30] * h_inv[30] + inv_W2[31] * h_inv[31] + inv_b2;
