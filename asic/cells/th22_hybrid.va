// th22_hybrid.va — TH22 C-element: IV-tables + analytical keeper.
//
// Pull-up, pull-down, and output inverter use NN/IV-table characterisation
// from transistor-level DC sweeps (auto-extracted, no hand-crafting).
// The keeper (weak-feedback latch) is a one-line analytical model:
//   I_keeper = (VDD - V(Y) - V(X)) / R_KEEP
// i.e. a weak inverter driving X toward (VDD - V(Y)) through R_KEEP.
// Hysteresis emerges from the keeper + C_X feedback loop — no state
// variable, no NN state memory, no hand-crafting needed.
//
// C_X = gate cap of inverter + keeper transistors (fixed per cell).
// C_Y = next-stage gate load (instance parameter, varies with fanout).

`include "disciplines.vams"
`include "constants.vams"

module th22_hybrid(A, B, Y, VDD, VSS);
  input  A, B, VDD, VSS;
  output Y;
  electrical A, B, Y, VDD, VSS;
  electrical X;

  // Keeper: one analytical parameter from DC sweep of MPK/MNK.
  parameter real R_KEEP = 8.0e4;   // ~80 kΩ (weak inverter drive R)

  // Gate caps: C_X from inverter+keeper gates, C_Y from next stage.
  parameter real C_X = 6.4e-15;   // MPY+MNY+MPK+MNK gate caps
  parameter real C_Y = 5.0e-15;   // external load (varies per instance)

  // Grid parameters for IV-table lookups.
  parameter real DX = 0.100000;   // V_X / V_Y grid step (13 pts over 1.2V)
  parameter real DG = 0.300000;   // V_A / V_B grid step (5 pts over 1.2V)

