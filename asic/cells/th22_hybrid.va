2085e-05, -2.8584e-05, -5.4458e-05, -8.9732e-05, -1.3296e-04, -1.8862e-11, -1.4524e-11, -2.1734e-11, -2.0952e-10, -3.5545e-09, -6.1441e-08, -7.6227e-07, -4.0367e-06, -1.2667e-05, -2.9479e-05, -5.6016e-05, -9.2207e-05, -1.3663e-04};

  // Interpolation locals
  real inv_c0, inv_c1, inv_fg, inv_fo, inv_v00, inv_v01, inv_v10, inv_v11, pd_c0, pd_c00, pd_c01, pd_c1, pd_c10, pd_c11, pd_fa, pd_fb, pd_fx, pd_v000, pd_v001, pd_v010, pd_v011, pd_v100, pd_v101, pd_v110, pd_v111, pu_c0, pu_c00, pu_c01, pu_c1, pu_c10, pu_c11, pu_fa, pu_fb, pu_fx, pu_v000, pu_v001, pu_v010, pu_v011, pu_v100, pu_v101, pu_v110, pu_v111;
  integer inv_ig, inv_io, pd_ia, pd_ib, pd_ix, pu_ia, pu_ib, pu_ix;

  real i_pu, i_pd, i_inv;

  analog begin
    // ---- Pull-up: NN/IV-table I(V_X, V_A, V_B) ----
    pu_fx = (V(X, VSS)) / 0.100000;
    if (pu_fx < 0.0) pu_fx = 0.0; if (pu_fx > 12) pu_fx = 12;
    pu_fa = (V(A, VSS)) / 0.300000;
    if (pu_fa < 0.0) pu_fa = 0.0; if (pu_fa > 4) pu_fa = 4;
    pu_fb = (V(B, VSS)) / 0.300000;
    if (pu_fb < 0.0) pu_fb = 0.0; if (pu_fb > 4) pu_fb = 4;
    pu_ix = floor(pu_fx); if (pu_ix > 11) pu_ix = 11;
    pu_ia = floor(pu_fa); if (pu_ia > 3) pu_ia = 3;
    pu_ib = floor(pu_fb); if (pu_ib > 3) pu_ib = 3;
    pu_fx = pu_fx - pu_ix; pu_fa = pu_fa - pu_ia; pu_fb = pu_fb - pu_ib;
    pu_v000 = T_PU[(pu_ix)*25+(pu_ia)*5+(pu_ib)];
    pu_v100 = T_PU[(pu_ix+1)*25+(pu_ia)*5+(pu_ib)];
    pu_v010 = T_PU[(pu_ix)*25+(pu_ia+1)*5+(pu_ib)];
    pu_v001 = T_PU[(pu_ix)*25+(pu_ia)*5+(pu_ib+1)];
    pu_v110 = T_PU[(pu_ix+1)*25+(pu_ia+1)*5+(pu_ib)];
    pu_v101 = T_PU[(pu_ix+1)*25+(pu_ia)*5+(pu_ib+1)];
    pu_v011 = T_PU[(pu_ix)*25+(pu_ia+1)*5+(pu_ib+1)];
    pu_v111 = T_PU[(pu_ix+1)*25+(pu_ia+1)*5+(pu_ib+1)];
    pu_c00 = pu_v000*(1-pu_fx)+pu_v100*pu_fx;
    pu_c10 = pu_v010*(1-pu_fx)+pu_v110*pu_fx;
    pu_c01 = pu_v001*(1-pu_fx)+pu_v101*pu_fx;
    pu_c11 = pu_v011*(1-pu_fx)+pu_v111*pu_fx;
    pu_c0 = pu_c00*(1-pu_fa)+pu_c10*pu_fa;
    pu_c1 = pu_c01*(1-pu_fa)+pu_c11*pu_fa;
    i_pu = pu_c0*(1-pu_fb)+pu_c1*pu_fb;


    // ---- Pull-down: NN/IV-table I(V_X, V_A, V_B) ----
    pd_fx = (V(X, VSS)) / 0.100000;
    if (pd_fx < 0.0) pd_fx = 0.0; if (pd_fx > 12) pd_fx = 12;
    pd_fa = (V(A, VSS)) / 0.300000;
    if (pd_fa < 0.0) pd_fa = 0.0; if (pd_fa > 4) pd_fa = 4;
    pd_fb = (V(B, VSS)) / 0.300000;
    if (pd_fb < 0.0) pd_fb = 0.0; if (pd_fb > 4) pd_fb = 4;
    pd_ix = floor(pd_fx); if (pd_ix > 11) pd_ix = 11;
    pd_ia = floor(pd_fa); if (pd_ia > 3) pd_ia = 3;
    pd_ib = floor(pd_fb); if (pd_ib > 3) pd_ib = 3;
    pd_fx = pd_fx - pd_ix; pd_fa = pd_fa - pd_ia; pd_fb = pd_fb - pd_ib;
    pd_v000 = T_PD[(pd_ix)*25+(pd_ia)*5+(pd_ib)];
    pd_v100 = T_PD[(pd_ix+1)*25+(pd_ia)*5+(pd_ib)];
    pd_v010 = T_PD[(pd_ix)*25+(pd_ia+1)*5+(pd_ib)];
    pd_v001 = T_PD[(pd_ix)*25+(pd_ia)*5+(pd_ib+1)];
    pd_v110 = T_PD[(pd_ix+1)*25+(pd_ia+1)*5+(pd_ib)];
    pd_v101 = T_PD[(pd_ix+1)*25+(pd_ia)*5+(pd_ib+1)];
    pd_v011 = T_PD[(pd_ix)*25+(pd_ia+1)*5+(pd_ib+1)];
    pd_v111 = T_PD[(pd_ix+1)*25+(pd_ia+1)*5+(pd_ib+1)];
    pd_c00 = pd_v000*(1-pd_fx)+pd_v100*pd_fx;
    pd_c10 = pd_v010*(1-pd_fx)+pd_v110*pd_fx;
    pd_c01 = pd_v001*(1-pd_fx)+pd_v101*pd_fx;
    pd_c11 = pd_v011*(1-pd_fx)+pd_v111*pd_fx;
    pd_c0 = pd_c00*(1-pd_fa)+pd_c10*pd_fa;
    pd_c1 = pd_c01*(1-pd_fa)+pd_c11*pd_fa;
    i_pd = pd_c0*(1-pd_fb)+pd_c1*pd_fb;


    // ---- Output inverter: NN/IV-table I(V_Y, V_X) ----
    inv_fo = (V(Y, VSS)) / 0.100000;
    if (inv_fo < 0.0) inv_fo = 0.0; if (inv_fo > 12) inv_fo = 12;
    inv_fg = (V(X, VSS)) / 0.100000;
    if (inv_fg < 0.0) inv_fg = 0.0; if (inv_fg > 12) inv_fg = 12;
    inv_io = floor(inv_fo); if (inv_io > 11) inv_io = 11;
    inv_ig = floor(inv_fg); if (inv_ig > 11) inv_ig = 11;
    inv_fo = inv_fo - inv_io; inv_fg = inv_fg - inv_ig;
    inv_v00 = T_INV[(inv_io)*13+(inv_ig)];
    inv_v10 = T_INV[(inv_io+1)*13+(inv_ig)];
    inv_v01 = T_INV[(inv_io)*13+(inv_ig+1)];
    inv_v11 = T_INV[(inv_io+1)*13+(inv_ig+1)];
    inv_c0 = inv_v00*(1-inv_fo)+inv_v10*inv_fo;
    inv_c1 = inv_v01*(1-inv_fo)+inv_v11*inv_fo;
    i_inv = inv_c0*(1-inv_fg)+inv_c1*inv_fg;


    // ---- Keeper: analytical weak inverter, ONE LINE ----
    // Drives X toward (VDD - V(Y)) through R_KEEP. At hold states
    // (X already at target), current is zero — hysteresis is maintained
    // by charge on C_X. During transitions, provides a weak restoring force.

    // ---- KCL at X: pull-up + pull-down + keeper + cap ----
    I(X, VSS) <+ -(i_pu + i_pd);
    I(X, VSS) <+ -(V(VDD, VSS) - V(Y, VSS) - V(X, VSS)) / R_KEEP;
    I(X, VSS) <+ C_X * ddt(V(X, VSS));

    // ---- KCL at Y: inverter + cap ----
    I(Y, VSS) <+ -i_inv;
    I(Y, VSS) <+ C_Y * ddt(V(Y, VSS));
  end
endmodule
